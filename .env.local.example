# Copy this file to .env.local and fill in every value.
#
#   cp .env.local.example .env.local
#
# Then pull and start:
#   docker compose --env-file .env.local pull
#   docker compose --env-file .env.local up -d

# ── Deployment ────────────────────────────────────────────────────────────────
# The domain Traefik serves on (no scheme, no trailing slash).
DOMAIN=your_domain

# Email address for Let's Encrypt certificate notifications.
ACME_EMAIL=you@example.com

# ── GitHub Container Registry ─────────────────────────────────────────────────
# Your GitHub username or organisation — used to resolve the image names:
#   ghcr.io/<GHCR_OWNER>/insighta-backend:latest  etc.
GHCR_OWNER=tony-nyagah

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → "New OAuth App"
# 2. Set these URLs:
#      Homepage URL    : https://<your_domain>/insighta
#      Callback URL    : https://<your_domain>/insighta/auth/callback
#      (also add http://127.0.0.1 as a second callback for local CLI use)
# 3. Paste the generated credentials below.
GITHUB_CLIENT_ID=Ov23lityH5wETUxSbFKa
GITHUB_CLIENT_SECRET=f3eb324027717649ad2e44b8443169c3763622f5

# GitHub redirects here after OAuth. For the web portal flow this must be the
# web portal's /auth/callback. The CLI overrides this with its own local server.
GITHUB_REDIRECT_URI=https://hng14.nyagah.me/insighta/auth/callback

# Browser-facing backend URL — used by the web portal and CLI to build OAuth
# redirect URLs that the browser opens. Must be publicly reachable.
PUBLIC_API_URL=https://hng14.nyagah.me/insighta

# ── JWT secret ────────────────────────────────────────────────────────────────
# Signs/verifies access tokens. Use a long random string.
# Generate one: openssl rand -hex 32
JWT_SECRET=139552849a9e3ee0b902f6560ecd1236c0abef1ebc34e2371881a04cfac823ca

# ── Web session keys (gorilla/securecookie) ───────────────────────────────────
# SESSION_HASH_KEY  — HMAC signing key, 32+ bytes
# SESSION_BLOCK_KEY — AES encryption key, must be exactly 32 bytes
#
# Generate:
#   openssl rand -hex 32          → SESSION_HASH_KEY
#   openssl rand -base64 24       → 32-character string, use as SESSION_BLOCK_KEY
SESSION_HASH_KEY=6f020d815707facd31ce486a6e21cee5af2365915a918319f06ca4e4c5f5f301
SESSION_BLOCK_KEY=Coi0UnyXfKoJBuQCRV+FUCofqBn51IU8

# ── CSRF protection ───────────────────────────────────────────────────────────
# Must be exactly 32 bytes.
# Generate: openssl rand -base64 24 | head -c 32
CSRF_AUTH_KEY=7MPAx4nWF03SmocOev2gYfF4i9jEPNLZ

# ── Environment ───────────────────────────────────────────────────────────────
# "production" enables Secure + SameSite cookies (requires HTTPS).
# Leave as "development" if testing locally without Traefik/HTTPS.
ENV=production
